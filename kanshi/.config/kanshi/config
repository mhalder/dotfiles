# Auto display profiles for sway/wlroots
# Match by connector name for portability on this host.

profile docked {
  output eDP-1 enable position 0,0 scale 1
  output DP-6 enable position 1920,0 scale 1.5
}

profile xray {
  output eDP-1 enable position 0,0 scale 1
  output DP-1 enable position 1920,0 scale 1
}

profile laptop {
  output eDP-1 enable position 0,0 scale 1
}

