# sway config file
#
# see `man 5 sway` for reference

# font for window titles and status bar
font pango:Cascadia Code, Regular 12

# set background
output * bg ~/.background.png fill
output DP-6 scale 1.5

# sway session env
exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway XDG_SESSION_DESKTOP=sway
exec mako
exec swayidle -w \
    timeout 900 'swaylock -f' \
    timeout 1800 'systemctl suspend' \
    before-sleep 'swaylock -f'
exec nm-applet

set $mod Mod4

# use mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# start a terminal
bindsym $mod+Return exec ghostty

# borders
# keep visible border so active window stands out
default_border pixel 1
default_floating_border pixel 1

# kill focused window
bindsym $mod+Shift+w kill

# start dmenu (a program launcher)
bindsym $mod+z exec wofi --show drun

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# split in horizontal orientation
bindsym $mod+g split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen

# change container layout (stacked, tabbed, default)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
bindsym $mod+d focus child

# workspace definition
set $ws1 "1 work"
set $ws2 "2 arkadia"
set $ws3 "3 private"
set $ws4 "4 apps"
set $ws5 "5 slack"
set $ws6 "6 sessions"
set $ws7 "7 vault"
set $ws8 "8 obsidian"
set $ws9 "9 music"

# switch to workspace
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9

bindsym $mod+b exec --no-startup-id google-chrome
bindsym $mod+shift+p exec --no-startup-id pavucontrol
bindsym $mod+shift+n exec --no-startup-id nautilus
bindsym $mod+shift+y exec --no-startup-id sh -c 'if command -v deskflow >/dev/null; then exec deskflow; elif command -v flatpak >/dev/null && flatpak info org.deskflow.deskflow >/dev/null 2>&1; then exec flatpak run org.deskflow.deskflow; else exec swaynag -t warning -m "deskflow not installed"; fi'
bindsym $mod+shift+m exec ghostty -e nmtui
bindsym $mod+shift+x exec swaylock -f

# move container
bindsym $mod+Shift+Right move workspace to output right
bindsym $mod+Shift+Left move workspace to output left
bindsym $mod+Shift+Up move workspace to output up
bindsym $mod+Shift+Down move workspace to output down

# screen brightness controls
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

# pulse audio controls
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +10% # increase sound volume
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@  -10% # decrease sound volume
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle # mute sound

# reload the configuration file
bindsym $mod+Shift+c reload
# restart sway in place
bindsym $mod+Shift+r restart

# resize window (you can also use the mouse for that)
mode "resize" {
  # these bindings trigger as soon as you enter the resize mode
  bindsym h resize shrink width 10 px or 10 ppt
  bindsym l resize grow width 10 px or 10 ppt
  bindsym j resize grow height 10 px or 10 ppt
  bindsym k resize shrink height 10 px or 10 ppt

  # back to normal: enter or escape
  bindsym Return mode "default"
  bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"

bar {
    swaybar_command waybar
}

# make the currently focused window a scratchpad
bindsym $mod+Shift+minus move scratchpad
#
# show the first scratchpad window
bindsym $mod+minus scratchpad show

# keyboard
input "type:keyboard" {
    xkb_layout "us,us"
    xkb_variant ",intl"
    xkb_options "grp:alt_shift_toggle"
    repeat_delay 250
    repeat_rate 45
}

# keyboard layout shortcuts
bindsym $mod+Shift+i input type:keyboard xkb_switch_layout 1
bindsym $mod+Shift+u input type:keyboard xkb_switch_layout 0
bindsym $mod+Shift+s exec sh -lc 'grim -g "$(slurp)" - | wl-copy'
bindsym $mod+Shift+a exec sh -lc 'mkdir -p ~/Pictures/screenshots && grim -g "$(slurp)" -t ppm - | ~/.cargo/bin/satty --filename - --output-filename ~/Pictures/screenshots/satty-$(date +"%Y-%m-%d_%H-%M-%S").png'
bindsym $mod+Shift+g exec --no-startup-id /opt/enpass/Enpass showassistant

# configure gaps
gaps inner 8
gaps outer 8

# dark theme colors
# class                 border  backgr. text    indicator child_border
client.focused          #145a32 #285577 #ffffff #145a32   #145a32
client.focused_inactive #666666 #5f676a #ffffff #484e50   #666666
client.unfocused        #333333 #222222 #888888 #292d2e   #333333
client.urgent           #ff0000 #900000 #ffffff #ff0000   #ff0000
client.placeholder      #000000 #0c0c0c #ffffff #000000   #0c0c0c
client.background       #ffffff

# Only enable outer gaps when there is exactly one window or split container on the workspace.
smart_gaps inverse_outer

# Auto-switch display profiles
exec_always kanshi
